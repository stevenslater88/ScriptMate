{
  "expo": {
    "name": "ScriptMate",
    "slug": "scriptmate",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scriptmate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scriptmate.app",
      "buildNumber": "8",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record audio for your self-tape auditions",
        "NSSpeechRecognitionUsageDescription": "Recognize when you finish speaking your lines",
        "NSCameraUsageDescription": "Record video self-tapes for auditions",
        "NSPhotoLibraryUsageDescription": "Save your self-tape recordings",
        "NSPhotoLibraryAddUsageDescription": "Save your self-tape recordings to your photo library",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.scriptmate.app",
      "versionCode": 8,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0f"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "scriptmate-app"
      }
    }
  }
}
